    "# This function defines how we evaluate the model during validation.\n",
    "# The Trainer passes in predictions and true labels through EvalPrediction.\n",
    "# We convert raw logits into class predictions using argmax,\n",
    "# then compute simple classification accuracy.\n",
    "\n",
    "import numpy as np\n",
    "from transformers import EvalPrediction\n",
    "\n",
    "def compute_metrics(p: EvalPrediction):\n",
    "\n",
    "    # Extract raw model outputs (logits).\n",
    "    # Depending on how the model returns outputs, predictions may come as a tuple.\n",
    "    preds = p.predictions[0] if isinstance(p.predictions, tuple) else p.predictions\n",
    "\n",
    "    # Convert logits into predicted class indices.\n",
    "    # Highest logit wins — nothing fancy here.\n",
    "    preds = np.argmax(preds, axis=1)\n",
    "\n",
    "    # Compute accuracy by comparing predictions to ground truth labels.\n",
    "    # This keeps evaluation straightforward and reproducible.\n",
    "    accuracy = (preds == p.label_ids).astype(np.float32).mean().item()\n",
    "\n",
    "    return {\"accuracy\": accuracy}"
   ]
  },
