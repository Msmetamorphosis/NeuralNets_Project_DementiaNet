    "# This data collator handles dynamic padding for speech inputs.\n",
    "# Audio clips are all different lengths, so we cannot batch them directly.\n",
    "# Instead, we pad each batch to the longest sequence in that batch only.\n",
    "# This keeps training efficient without wasting memory.\n",
    "\n",
    "from dataclasses import dataclass\n",
    "from typing import Dict, List, Optional, Union\n",
    "import torch\n",
    "\n",
    "from transformers import Wav2Vec2FeatureExtractor\n",
    "\n",
    "\n",
    "@dataclass\n",
    "class DataCollatorCTCWithPadding:\n",
    "\n",
    "    # Feature extractor is responsible for padding raw audio tensors correctly.\n",
    "    # We reuse it here to ensure padding stays consistent with model expectations.\n",
    "    feature_extractor: Wav2Vec2FeatureExtractor\n",
    "\n",
    "    # Padding strategy. Default is dynamic padding to the longest sample in batch.\n",
    "    padding: Union[bool, str] = True\n",
    "\n",
    "    # Optional controls if we ever want to enforce max length limits.\n",
    "    max_length: Optional[int] = None\n",
    "    max_length_labels: Optional[int] = None\n",
    "    pad_to_multiple_of: Optional[int] = None\n",
    "    pad_to_multiple_of_labels: Optional[int] = None\n",
    "\n",
    "    def __call__(self, features: List[Dict[str, Union[List[int], torch.Tensor]]]) -> Dict[str, torch.Tensor]:\n",
    "\n",
    "        # Extract input audio arrays\n",
    "        input_features = [{\"input_values\": feature[\"input_values\"]} for feature in features]\n",
    "\n",
    "        # Extract labels separately\n",
    "        label_features = [feature[\"labels\"] for feature in features]\n",
    "\n",
    "        # Determine correct tensor type for labels\n",
    "        d_type = torch.long if isinstance(label_features[0], int) else torch.float\n",
    "\n",
    "        # Pad audio inputs to match longest sequence in the batch\n",
    "        # This avoids forcing all samples to global max length.\n",
    "        batch = self.feature_extractor.pad(\n",
    "            input_features,\n",
    "            padding=self.padding,\n",
    "            max_length=self.max_length,\n",
    "            pad_to_multiple_of=self.pad_to_multiple_of,\n",
    "            return_tensors=\"pt\",\n",
    "        )\n",
    "\n",
    "        # Attach labels back to the batch\n",
    "        batch[\"labels\"] = torch.tensor(label_features, dtype=d_type)\n",
    "\n",
    "        return batch"
   ]
  },
