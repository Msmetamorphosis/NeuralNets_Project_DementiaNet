    "import json\n",
    "\n",
    "IN_PATH = \"/content/drive/MyDrive/CS7357_Project/data/02-finetune.ipynb\"\n",
    "OUT_PATH = \"/content/drive/MyDrive/CS7357_Project/data/02-finetune.github.ipynb\"\n",
    "\n",
    "WIDGET_MIMES = {\n",
    "    \"application/vnd.jupyter.widget-view+json\",\n",
    "    \"application/vnd.jupyter.widget-state+json\",\n",
    "}\n",
    "\n",
    "def scrub_widgets(obj):\n",
    "    if isinstance(obj, dict):\n",
    "        # Remove widget metadata at any level\n",
    "        obj.pop(\"widgets\", None)\n",
    "        for k, v in list(obj.items()):\n",
    "            obj[k] = scrub_widgets(v)\n",
    "    elif isinstance(obj, list):\n",
    "        return [scrub_widgets(i) for i in obj]\n",
    "    return obj\n",
    "\n",
    "with open(IN_PATH, \"r\", encoding=\"utf-8\") as f:\n",
    "    nb = json.load(f)\n",
    "\n",
    "# Remove metadata.widgets completely\n",
    "if \"metadata\" in nb:\n",
    "    nb[\"metadata\"].pop(\"widgets\", None)\n",
    "\n",
    "# Deep scrub any nested widget metadata\n",
    "nb = scrub_widgets(nb)\n",
    "\n",
    "# Remove widget MIME outputs but keep everything else\n",
    "for cell in nb.get(\"cells\", []):\n",
    "    if \"outputs\" in cell:\n",
    "        cleaned_outputs = []\n",
    "        for out in cell[\"outputs\"]:\n",
    "            if \"data\" in out:\n",
    "                out[\"data\"] = {\n",
    "                    k: v for k, v in out[\"data\"].items()\n",
    "                    if k not in WIDGET_MIMES\n",
    "                }\n",
    "            cleaned_outputs.append(out)\n",
    "        cell[\"outputs\"] = cleaned_outputs\n",
    "\n",
    "with open(OUT_PATH, \"w\", encoding=\"utf-8\") as f:\n",
    "    json.dump(nb, f, ensure_ascii=False, indent=1)\n",
    "\n",
    "print(\"Saved GitHub-safe notebook to:\", OUT_PATH)"
   ],
