        "**Compute Class Weights**\n",
        "\n",
        "Compute class weights from the training labels to compensate for class imbalance between dementia and nondementia recordings.\n",
        "\n",
        "These weights are later used in the loss function so that errors on the minority class receive greater penalty during training."
      ],
      "metadata": {
        "id": "LxHwbpooBaN9"
      }
    },
    {
      "cell_type": "code",
      "source": [
        "from sklearn.utils.class_weight import compute_class_weight\n",
        "import numpy as np\n",
        "import torch\n",
        "\n",
        "# Convert labels to numeric if they are still strings\n",
        "label_map = {\"nodementia\": 0, \"dementia\": 1}\n",
        "train_labels = train_df[\"label\"].map(label_map).values\n",
        "\n",
        "classes = np.unique(train_labels)\n",
        "\n",
        "class_weights = compute_class_weight(\n",
        "    class_weight=\"balanced\",\n",
        "    classes=classes,\n",
        "    y=train_labels\n",
        ")\n",
        "\n",
        "class_weights = torch.tensor(class_weights, dtype=torch.float)\n",
        "\n",
        "print(\"classes:\", classes)\n",
        "print(\"class_weights:\", class_weights)"
      ],
